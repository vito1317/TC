TAC {
    designs: [
        Test2 {
            int a0 0
        }
    ]
    entry_point: main
    subroutines: [
        Test2.constructor {
            parameters: []
            local: [
                Test2 t0
                Test2 t1
            ]
            instructions: [
                b0 {
                    alloc t0 Test2 4
                    set_attr t0 a0 5
                    param 4 t0
                    call  t1 Test2.init 1
                    ret   t1
                }
            ]
        }
        Test2.init {
            parameters: [
                Test2 p0
            ]
            local: [
                int t2
            ]
            instructions: [
                b1 {
                    get_attr t2 p0 a0
                    param 4 t2
                    call  void print 1
                    ret   p0
                }
            ]
        }
        Test2.set_x {
            parameters: [
                Test2 p1
                int   p2
            ]
            local: []
            instructions: [
                b2 {
                    set_attr p1 a0 p2
                    ret      void
                }
            ]
        }
        Test2.get_x {
            parameters: [
                Test2 p3
            ]
            local: [
                int t3
            ]
            instructions: [
                b3 {
                    get_attr t3 p3 a0
                    ret      t3
                }
            ]
        }
        main {
            parameters: []
            local: [
                Test2 v0
                arr   v1
                int   t4
                int   t5
                int   t6
                int   t7
                int   t8
                int   t9
                int   t10
                int   t11
                int   t12
            ]
            instructions: [
                b4 {
                    // var Test2 t = Test2();
                    call  v0 Test2.constructor 0
                    // var arr nums = arr("int", 10);
                    param 1 "int"
                    param 4 10
                    call  v1 arr 2
                    // nums[0] = 42;
                    set_elem v1 0 42
                    // t.set_x(2 + t.get_x() * 10);
                    param 4 v0
                    param 4 v0
                    call  t4 Test2.get_x 1
                    mul   t5 t4 10
                    add   t6 2 t5
                    param 4 t6
                    call  void Test2.set_x 2
                    // print(t.get_x());
                    param 4 v0
                    call  t7 Test2.get_x 1
                    param 4 t7
                    call  void print 1
                    // t.set_x(nums[0] + 10 - 2 * 5);
                    param 4 v0
                    mul   t8 2 5
                    get_elem t9 v1 0
                    add   t10 t9 10
                    sub   t11 t10 t8
                    param 4 t11
                    call  void Test2.set_x 2
                    // print(t.get_x());
                    param 4 v0
                    call  t12 Test2.get_x 1
                    param 4 t12
                    call  void print 1
                    // return 0;
                    ret   0
                }
            ]
        }
    ]
}
